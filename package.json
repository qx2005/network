{
  "name": "5g-config-platform",
  "private": true,
  "workspaces": ["apps/web", "apps/api"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run start:dev -w api\" \"npm run dev -w web\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run start:dev -w api",
    "build": "npm run build -w api && npm run build -w web",
    "lint": "npm run lint -w web",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
